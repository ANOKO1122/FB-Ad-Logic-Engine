      "method": "GET",
      "headers": [
        {"key": "Authorization", "value": "Bearer {{token}}"}
      ],
      "body": {}
    },
    {
      "name": "4. sync-强制同步结构",
      "url": "http://localhost:3001/api/sync/structure",
