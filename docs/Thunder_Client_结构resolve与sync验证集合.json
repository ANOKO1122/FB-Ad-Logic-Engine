      "headers": [
        {"key": "Authorization", "value": "Bearer {{token}}"}
      ],
      "body": {}
    },
    {
      "name": "2. resolve-DB_miss返回missing",
      "url": "http://localhost:3001/api/structure/resolve?ids=99999999999999,88888888888888",
      "method": "GET",
      "headers": [
        {"key": "Authorization", "value": "Bearer {{token}}"}
      ],
      "body": {}
    },
    {
      "name": "3. resolve-混合(存在+不存在)",
