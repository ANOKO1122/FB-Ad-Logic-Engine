{
  "clientName": "Thunder Client",
  "collectionName": "阶段1验证测试",
  "folders": [],
  "requests": [
    {
      "name": "1. 登录 - test2 (staff)",
      "url": "http://localhost:3000/api/auth/login",
      "method": "POST",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": {
        "type": "json",
        "raw": "{\n  \"username\": \"test2\",\n  \"password\": \"your_password\"\n}"
      },
      "tests": [],
      "note": "用 test2 测试时：1. 先发本请求 2. 从返回 JSON 复制 token 3. 在 2～7 的请求里，Headers 的 Authorization 把「登录test2后在此粘贴token」整段换成「Bearer 刚复制的token」"
    },
    {
      "name": "2. Summary接口 - 非admin (test2)",
      "url": "http://localhost:3000/api/automation-logs/stats/summary",
      "method": "GET",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer 登录test2后在此粘贴token"
        }
      ],
      "tests": []
    },
    {
