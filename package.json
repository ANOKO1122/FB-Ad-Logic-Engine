{
  "name": "facebook-marketing-api-monitor",
  "version": "1.0.0",
  "description": "Facebook Marketing API实时监控和自动规则系统",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node server/server.js",
    "dev:server:logs": "set NODE_ENV=production&& node server/server.js",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev\"",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "export:pg": "node server/scripts/export-facebook-to-pg.js"
  },
  "dependencies": {
    "@vuepic/vue-datepicker": "^11.0.2",
    "axios": "^1.6.2",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dayjs": "^1.11.10",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^4.18.2",
    "https-proxy-agent": "^7.0.2",
    "jsonwebtoken": "^9.0.3",
    "luxon": "^3.7.2",
    "mysql2": "^3.16.0",
    "node-cron": "^4.2.1",
    "p-limit": "^7.2.0",
    "pg": "^8.20.0",
    "socks-proxy-agent": "^8.0.2",
    "undici": "^5.28.2",
    "vue": "^3.4.0",
    "vue-router": "^4.6.4",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^4.0.16",
    "concurrently": "^8.2.2",
    "supertest": "^7.2.2",
    "vite": "^5.0.0",
    "vitest": "^4.0.16"
  }
}
