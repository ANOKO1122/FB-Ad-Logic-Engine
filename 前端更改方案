<script>
import { ref, onMounted, computed } from 'vue'
import ruleEngine from '../services/ruleEngine'
import facebookApi from '../services/facebookApi'

export default {
  name: 'RuleManager',
  setup() {
    // ... existing refs ...
    const rules = ref([])
    const showRuleModal = ref(false)
    const editingRuleId = ref(null)
    const running = ref(false)
    
    // 升级表单数据结构
    const ruleForm = ref({
      name: '',
      enabled: true,
      is_simulation: false, // 新增
      target_level: 'ad',   // 新增
      target_ids: [],       // 新增
      logic_operator: 'AND', // 新增
      conditions: [],
      actions: []
    })

    const levelOptions = [
      { label: '广告 (Ad)', value: 'ad' },
      { label: '广告组 (AdSet)', value: 'adset' },
      { label: '广告系列 (Campaign)', value: 'campaign' }
    ]

    // 临时的 ID 字符串处理 (用于 input <-> array 转换)
    const targetIdsString = computed({
      get: () => ruleForm.value.target_ids.join(', '),
      set: (val) => {
        ruleForm.value.target_ids = val.split(',').map(s => s.trim()).filter(Boolean)
      }
    })

    // ... existing loadRules ...
    const loadRules = () => {
      rules.value = ruleEngine.getRules()
    }

    // ... existing metricLabel/opLabel ...
    const metricLabel = (m) => {
      const map = { spend: '花费', roas: 'ROAS', cpa: 'CPA', ctr: 'CTR', cpc: 'CPC', clicks: '点击', purchases: '购买' }
      return map[m] || m
    }
    
    // 新增 openCreateRule
    const openCreateRule = () => {
      editingRuleId.value = null
      ruleForm.value = {
        name: '',
        enabled: true,
        is_simulation: false,
        target_level: 'ad',
        target_ids: [],
        logic_operator: 'AND',
        conditions: [{ metric: 'spend', operator: 'gt', value: 20, time_window: 'today' }],
        actions: [{ type: 'pause', value: null }]
      }
      showRuleModal.value = true
    }

    // 新增 openEditRule
    const openEditRule = (r) => {
      editingRuleId.value = r.id
      ruleForm.value = JSON.parse(JSON.stringify({
        name: r.name,
        enabled: r.enabled,
        is_simulation: r.is_simulation || false,
        target_level: r.target_level || 'ad',
        target_ids: r.target_ids || [],
        logic_operator: r.logic_operator || 'AND',
        conditions: r.conditions || [],
        actions: r.actions || []
      }))
      showRuleModal.value = true
    }

    // 辅助方法
    const addCondition = () => {
      ruleForm.value.conditions.push({ metric: 'spend', operator: 'gt', value: 0, time_window: 'today' })
    }
    
    const addAction = () => {
      ruleForm.value.actions.push({ type: 'pause', value: null })
    }

    // 模板功能
    const applyTemplate = (type) => {
      if (!confirm('这将覆盖当前的条件设置，确定吗？')) return
      if (type === 'stop_loss') {
        // 止损模板：花费 > 20 且 ROAS < 0.5 (今天)
        ruleForm.value.conditions = [
          { metric: 'spend', operator: 'gt', value: 20, time_window: 'today' },
          { metric: 'roas', operator: 'lt', value: 0.5, time_window: 'today' }
        ]
        ruleForm.value.logic_operator = 'AND'
        ruleForm.value.actions = [{ type: 'pause', value: null }]
      } else if (type === 'scale_up') {
        // 扩量模板：ROAS > 2 (近3天)
        ruleForm.value.conditions = [
          { metric: 'roas', operator: 'gt', value: 2, time_window: 'last_3_days' }
        ]
        ruleForm.value.actions = [{ type: 'increase_budget', value: 20 }]
      }
    }

    const saveRule = () => {
      if (!ruleForm.value.name.trim()) return alert('请输入规则名称')
      
      const payload = JSON.parse(JSON.stringify(ruleForm.value))
      
      if (editingRuleId.value) {
        ruleEngine.updateRule(editingRuleId.value, payload)
      } else {
        ruleEngine.addRule(payload)
      }
      showRuleModal.value = false
      loadRules()
    }

    // ... existing deleteRule/toggleRule ...
    const deleteRule = (r) => {
        if (!confirm(`确定删除「${r.name}」吗？`)) return
        ruleEngine.deleteRule(r.id)
        loadRules()
    }

    const toggleRule = (r, checked) => {
        ruleEngine.toggleRule(r.id, checked)
        loadRules()
    }
    
    const runRulesNow = async () => { /* ... existing code ... */ }

    // ... existing getActionClass ...
    const getActionClass = (type) => {
        if (type === 'pause') return 'danger'
        if (type === 'activate') return 'success'
        return 'primary'
    }
    const opLabel = (op) => {
      const map = { gt: '>', lt: '<', gte: '≥', lte: '≤', eq: '=' }
      return map[op] || op
    }
    const actionLabel = (t) => {
      const map = { pause: '暂停', activate: '开启', increase_budget: '加预算', decrease_budget: '减预算' }
      return map[t] || t
    }


    onMounted(loadRules)

    return {
      rules, showRuleModal, editingRuleId, ruleForm, running,
      levelOptions, targetIdsString,
      loadRules, metricLabel, opLabel, actionLabel, getActionClass,
      openCreateRule, openEditRule, saveRule, deleteRule, toggleRule, runRulesNow,
      addCondition, addAction, applyTemplate
    }
  }
}
</script>

